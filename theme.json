{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "color": {
            "palette": [
              {
                "color":"#1FBB00",
                "name":"Primary",
                "slug":"primary"
              },
              {
                "color":"#051A00",
                "name":"Secondary",
                "slug":"secondary"
              },
              {
                "color":"#B35B00",
                "name":"Accent",
                "slug":"accent"
              },
              {
                "color":"#FFFFFF",
                "name":"Background",
                "slug":"background"
              },
              {
                "color":"#093400",
                "name":"Surface",
                "slug":"surface"
              },
              {
                "color":"#041200",
                "name":"Heading",
                "slug":"heading"
              },
              {
                "color":"#2A2A2A",
                "name":"Text",
                "slug":"text"
              },
              {
                "color":"#0F5900",
                "name":"Success",
                "slug":"success"
              },
              {
                "color":"#DEDC00",
                "name":"Warning",
                "slug":"warning"
              },
              {
                "color":"#8A0000",
                "name":"Danger",
                "slug":"danger"
              }
              
              

            ],
            "gradients": [],
            "duotone": [],
            "custom": true,
            "customDuotone": true,
            "customGradient": true,
            "defaultGradients": true,
            "defaultPalette": false,
            "link": true,
            "text": true,
            "background": true,
            "heading": true,
            "enableAlpha": true
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
                    "name": "System Font",
                    "slug": "system-font"
                }
            ],
            "fontSizes": [],
            "fluid": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true,
            "units": ["px", "em", "rem", "%", "vh", "vw"],
            "customSpacingSize": true,
            "spacingSizes": []
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true,
            "customColor": true,
            "customRadius": true,
            "customStyle": true,
            "customWidth": true
        },
        "shadow": {
            "presets": [],
            "defaultPresets": true
        },
        "layout": {
            "contentSize": "800px",
            "wideSize": "1200px",
            "allowEditing": true,
            "allowCustomContentAndWideSize": true,
            "allowInfiniteScroll": false
        },
        "position": {
            "sticky": true,
            "fixed": true
        },
        "dimensions": {
            "minHeight": true,
            "aspectRatio": true
        },
        "blocks": {
            "core/paragraph": {},
            "core/heading": {},
            "core/button": {},
            "core/image": {},
            "core/group": {},
            "core/columns": {},
            "core/cover": {},
            "core/gallery": {}
        },
        "custom": {},
        "lightbox": {
            "enabled": true,
            "allowEditing": true
        },
        "background": {
            "backgroundImage": true,
            "backgroundSize": true,
            "backgroundRepeat": true,
            "backgroundPosition": true
        },
        "useRootPaddingAwareAlignments": true,
        "customSpacingSize": true,
        "customUnits": ["px", "em", "rem", "%"],
        "enableBlockBinding": true
    },
    "styles": {}
}